{
  "manifest_version": 3,
  "name": "papio",
  "version": "0.6.0",
  "description": "Fetch scholarly PDFs through your library in your own signed-in browser. You handle login and CAPTCHAs; papio downloads the paper.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "tabs",
    "downloads",
    "scripting",
    "storage",
    "alarms",
    "tabGroups"
  ],
  "host_permissions": [
    "https://*.alma.exlibrisgroup.com/*",
    "https://*.primo.exlibrisgroup.com/*"
  ],
  "optional_host_permissions": [
    "https://www.jstor.org/*",
    "https://www.proquest.com/*",
    "https://research.ebsco.com/*",
    "https://link.springer.com/*",
    "https://www.sciencedirect.com/*",
    "https://dl.acm.org/*",
    "https://onlinelibrary.wiley.com/*",
    "https://www.tandfonline.com/*",
    "https://journals.sagepub.com/*",
    "https://psycnet.apa.org/*",
    "https://*/*"
  ],
  "options_page": "dist/options.html",
  "action": {
    "default_title": "papio",
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
