{
  "manifest_version": 3,
  "name": "Papio",
  "version": "0.2.0",
  "description": "Ordinary-Chrome institutional handoff for the papio paper-acquisition broker. Human login stays human; one explicitly requested download per job.",
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "tabs",
    "downloads",
    "scripting",
    "storage"
  ],
  "optional_host_permissions": [
    "https://www.jstor.org/*",
    "https://www.proquest.com/*",
    "https://research.ebsco.com/*",
    "https://link.springer.com/*"
  ],
  "options_page": "dist/options.html",
  "action": {
    "default_title": "Papio",
    "default_popup": "dist/popup.html"
  }
}
