# Extension store submission credentials. Copy to extension/.env and fill in.
# extension/.env is gitignored — never commit real credentials.

# Firefox / addons.mozilla.org (AMO) — used by scripts/submit-firefox.sh.
# Generate at https://addons.mozilla.org/developers/addon/api/key/
WEB_EXT_API_KEY=
WEB_EXT_API_SECRET=

# Chrome Web Store — used by scripts/submit-chrome.sh.
# See docs/chrome-web-store-listing.md for minting the OAuth refresh token.
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=
CWS_REFRESH_TOKEN=
CWS_EXTENSION_ID=
# Developer Dashboard > Publisher > Settings (required by CWS API v2).
CWS_PUBLISHER_ID=
