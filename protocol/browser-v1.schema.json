{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papio.dev/protocol/browser-v1.schema.json",
  "title": "papio browser bridge message v1",
  "description": "One framed native-messaging envelope between the MV3 extension and the papio native host. Locked protocol papio-browser/1. Metadata only — PDF bytes and secrets never cross this channel; encoded messages are capped at 262144 bytes; integers are capped at JavaScript's exact range; unknown types, fields, and null object members are rejected (fail closed). auth_pending/auth_returned deliberately have no URL/title fields: identity-provider addresses never leave the browser.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "type", "msg_id", "seq", "payload"],
  "properties": {
    "protocol": { "const": "papio-browser/1" },
    "type": {
      "enum": [
        "hello",
        "hello_ack",
        "page_acquire",
        "page_acquire_ack",
        "job_offer",
        "handoff_outcome",
        "job_accept",
        "job_reject",
        "auth_pending",
        "auth_returned",
        "download_started",
        "download_complete",
        "provider_outcome",
        "cancel",
        "ack",
        "error",
        "triage_snapshot_request",
        "triage_snapshot_response",
        "triage_counts_request",
        "triage_counts_response",
        "triage_decide",
        "triage_decide_result",
        "human_action_resolve",
        "human_action_resolve_result",
        "review_preview_request",
        "review_preview_result"
      ]
    },
    "msg_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
    "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,128}$" },
    "seq": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "payload": { "type": "object" }
  },
  "$defs": {
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pending_total", "watch_hits", "actions", "retractions", "jobs_working", "jobs_needs_review", "failure_groups_7d"],
      "properties": {
        "pending_total": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "watch_hits": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "actions": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "retractions": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "jobs_working": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "jobs_needs_review": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "failure_groups_7d": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text"],
      "properties": {
        "label": { "type": "string", "maxLength": 40, "pattern": "^[^\\u0000]*$" },
        "text": { "type": "string", "maxLength": 400, "pattern": "^[^\\u0000]*$" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rel", "url"],
      "properties": {
        "rel": { "enum": ["doi", "arxiv", "openalex", "landing", "preview"] },
        "url": { "type": "string", "format": "uri", "maxLength": 4000, "pattern": "^https://[^\\u0000]+$" }
      }
    },
    "item_core": {
      "type": "object",
      "required": ["kind", "id", "rank", "title", "facts", "links", "ops"],
      "properties": {
        "kind": { "enum": ["watch_hit", "human_action", "retraction"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000]+$" },
        "rank": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "title": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" },
        "facts": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/fact" } },
        "links": { "type": "array", "maxItems": 16, "items": { "$ref": "#/$defs/link" } },
        "ops": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["acquire", "dismiss", "accept", "reject", "open", "retry"] }
        }
      }
    },
    "watch_hit_item": {
      "allOf": [
        { "$ref": "#/$defs/item_core" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id", "rank", "title", "facts", "links", "ops", "work", "abstract", "watches", "first_seen_at"],
          "properties": {
            "kind": { "const": "watch_hit" },
            "id": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000]+$" },
            "rank": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "title": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" },
            "facts": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/fact" } },
            "links": { "type": "array", "maxItems": 16, "items": { "$ref": "#/$defs/link" } },
            "ops": { "type": "array", "uniqueItems": true, "items": { "enum": ["acquire", "dismiss", "accept", "reject", "open", "retry"] } },
            "work": {
              "type": "object",
              "additionalProperties": false,
              "required": ["doi", "title", "authors", "year", "is_oa"],
              "properties": {
                "doi": { "type": "string", "maxLength": 300, "pattern": "^[^\\u0000]*$" },
                "title": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" },
                "authors": { "type": "string", "maxLength": 200, "pattern": "^[^\\u0000]*$" },
                "year": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
                "is_oa": { "type": "boolean" }
              }
            },
            "abstract": { "type": "string", "maxLength": 2000, "pattern": "^[^\\u0000]*$" },
            "watches": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "label"],
                "properties": {
                  "id": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
                  "label": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" }
                }
              }
            },
            "first_seen_at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "human_action_item": {
      "allOf": [
        { "$ref": "#/$defs/item_core" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id", "rank", "title", "facts", "links", "ops", "action_id", "job_id", "action_kind", "job_state", "revision", "sha256", "size_bytes"],
          "properties": {
            "kind": { "const": "human_action" },
            "id": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000]+$" },
            "rank": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "title": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" },
            "facts": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/fact" } },
            "links": { "type": "array", "maxItems": 16, "items": { "$ref": "#/$defs/link" } },
            "ops": { "type": "array", "uniqueItems": true, "items": { "enum": ["acquire", "dismiss", "accept", "reject", "open", "retry"] } },
            "action_id": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
            "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,128}$" },
            "action_kind": { "type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[^\\u0000]+$" },
            "job_state": { "type": "string", "minLength": 1, "maxLength": 50, "pattern": "^[^\\u0000]+$" },
            "revision": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
            "sha256": { "type": "string", "pattern": "^(|[a-f0-9]{64})$" },
            "size_bytes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
          }
        }
      ]
    },
    "retraction_item": {
      "allOf": [
        { "$ref": "#/$defs/item_core" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id", "rank", "title", "facts", "links", "ops", "doi", "nature", "noticed_at"],
          "properties": {
            "kind": { "const": "retraction" },
            "id": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000]+$" },
            "rank": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "title": { "type": "string", "maxLength": 500, "pattern": "^[^\\u0000]*$" },
            "facts": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/fact" } },
            "links": { "type": "array", "maxItems": 16, "items": { "$ref": "#/$defs/link" } },
            "ops": { "type": "array", "uniqueItems": true, "items": { "enum": ["acquire", "dismiss", "accept", "reject", "open", "retry"] } },
            "doi": { "type": "string", "minLength": 1, "maxLength": 300, "pattern": "^[^\\u0000]+$" },
            "nature": { "enum": ["retraction", "correction", "concern"] },
            "noticed_at": { "type": "string", "format": "date-time" },
            "notice_doi": { "type": "string", "maxLength": 300, "pattern": "^[^\\u0000]*$" }
          }
        }
      ]
    },
    "triage_item": {
      "oneOf": [
        { "$ref": "#/$defs/watch_hit_item" },
        { "$ref": "#/$defs/human_action_item" },
        { "$ref": "#/$defs/retraction_item" }
      ]
    },
    "mutation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "outcome"],
      "properties": {
        "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
        "outcome": { "enum": ["applied", "already_applied", "conflict", "error"] },
        "detail": { "type": "string", "maxLength": 1000, "pattern": "^[^\\u0000]*$" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "enum": ["job_offer", "handoff_outcome", "job_accept", "job_reject", "auth_pending", "auth_returned", "download_started", "download_complete", "provider_outcome", "cancel"] } } },
      "then": { "required": ["job_id"] }
    },
    {
      "if": { "properties": { "type": { "const": "hello" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["extension_version"],
            "properties": {
              "extension_version": { "type": "string", "maxLength": 50 },
              "adapter_versions": {
                "type": "object",
                "maxProperties": 50,
                "additionalProperties": { "type": "string", "maxLength": 50 }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "hello_ack" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "daemon_version": { "type": "string", "maxLength": 50 },
              "features": {
                "type": "array",
                "maxItems": 32,
                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
              },
              "resolver_origins": {
                "type": "array",
                "maxItems": 32,
                "items": { "type": "string", "maxLength": 300, "pattern": "^https://[a-z0-9.-]{3,253}(:[0-9]{1,5})?$" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "page_acquire" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["url"],
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "maxLength": 4000,
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://.+",
                "allOf": [{ "pattern": "^[^\\u0000]*$" }]
              },
              "doi": { "type": "string", "maxLength": 512, "pattern": "^[^\\u0000]*$" },
              "title": { "type": "string", "maxLength": 1024, "pattern": "^[^\\u0000]*$" },
              "source": { "type": "string", "maxLength": 1024, "pattern": "^[^\\u0000]*$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "page_acquire_ack" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "oneOf": [
              {
                "required": ["job_id"],
                "not": { "required": ["error"] }
              },
              {
                "required": ["error"],
                "not": { "required": ["job_id"] }
              }
            ],
            "allOf": [
              {
                "if": { "properties": { "duplicate": { "const": true } }, "required": ["duplicate"] },
                "then": { "required": ["job_id"] }
              }
            ],
            "properties": {
              "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,128}$" },
              "duplicate": { "type": "boolean" },
              "error": { "type": "string", "minLength": 1, "maxLength": 1000, "pattern": "^[^\\u0000]+$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "job_offer" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["openurl", "provider_hosts", "access_mode", "expires_at"],
            "properties": {
              "openurl": { "type": "string", "format": "uri", "maxLength": 4000 },
              "provider_hosts": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "items": { "type": "string", "pattern": "^[a-z0-9.-]{3,253}$" }
              },
              "expected": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "doi": { "type": "string", "maxLength": 300 },
                  "title": { "type": "string", "maxLength": 500 }
                }
              },
              "access_mode": { "enum": ["assisted", "maximal"] },
              "login_entity_id": { "type": "string", "format": "uri", "maxLength": 4000, "pattern": "^https://" },
              "proquest_account_id": { "type": "string", "maxLength": 64, "pattern": "^[0-9]+$" },
              "requires_auth": { "type": "boolean" },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "handoff_outcome" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["outcome", "final_host"],
            "properties": {
              "outcome": { "enum": ["stale_sso", "auth_error"] },
              "final_host": { "type": "string", "pattern": "^[a-z0-9.-]{3,253}$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "enum": ["auth_pending", "auth_returned"] } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "elapsed_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "download_started" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["download_id", "filename"],
            "properties": {
              "download_id": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
              "filename": { "type": "string", "pattern": "^[^/\\\\]{1,255}$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "download_complete" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["download_id", "filename", "size_bytes"],
            "properties": {
              "download_id": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
              "filename": { "type": "string", "pattern": "^[^/\\\\]{1,255}$" },
              "size_bytes": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "provider_outcome" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["outcome"],
            "properties": {
              "outcome": {
                "enum": [
                  "no_entitlement",
                  "document_delivery_available",
                  "wrong_work",
                  "ui_changed",
                  "rate_limited",
                  "terms_acceptance_required",
                  "human_auth_required",
                  "cancelled"
                ]
              },
              "adapter_version": { "type": "string", "maxLength": 50 },
              "detail": { "type": "string", "maxLength": 500 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "error" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string", "pattern": "^[a-z0-9_]{2,50}$" },
              "message": { "type": "string", "maxLength": 1000 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "triage_snapshot_request" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "schema_versions"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "schema_versions": { "type": "array", "minItems": 1, "maxItems": 1, "items": { "const": 1 } },
              "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
              "cursor": { "type": "string", "maxLength": 256, "pattern": "^[^\\u0000]*$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "triage_snapshot_response" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "schema", "generated_at", "counts", "items", "has_more", "unsupported_items_count"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "schema": { "const": 1 },
              "generated_at": { "type": "string", "format": "date-time" },
              "counts": { "$ref": "#/$defs/counts" },
              "items": { "type": "array", "maxItems": 100, "items": { "$ref": "#/$defs/triage_item" } },
              "cursor": { "type": "string", "maxLength": 256, "pattern": "^[^\\u0000]*$" },
              "has_more": { "type": "boolean" },
              "unsupported_items_count": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
            },
            "allOf": [
              { "if": { "properties": { "has_more": { "const": true } }, "required": ["has_more"] }, "then": { "required": ["cursor"] } },
              { "if": { "properties": { "has_more": { "const": false } }, "required": ["has_more"] }, "then": { "not": { "required": ["cursor"] } } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "triage_counts_request" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id"],
            "properties": { "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "triage_counts_response" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "counts"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "counts": { "$ref": "#/$defs/counts" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "triage_decide" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "item_id", "op"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "item_id": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000]+$" },
              "op": { "enum": ["acquire", "dismiss"] },
              "watch_scope": {
                "oneOf": [
                  { "const": "all" },
                  { "type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 } }
                ]
              }
            },
            "allOf": [
              { "if": { "properties": { "op": { "const": "dismiss" } }, "required": ["op"] }, "then": { "required": ["watch_scope"] } },
              { "if": { "properties": { "op": { "const": "acquire" } }, "required": ["op"] }, "then": { "not": { "required": ["watch_scope"] } } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "enum": ["triage_decide_result", "human_action_resolve_result"] } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/mutation_result" } } }
    },
    {
      "if": { "properties": { "type": { "const": "human_action_resolve" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "action_id", "verdict", "expected_revision"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "action_id": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
              "verdict": { "enum": ["accept", "reject", "dismiss"] },
              "expected_revision": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
              "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            },
            "allOf": [
              { "if": { "properties": { "verdict": { "const": "accept" } }, "required": ["verdict"] }, "then": { "required": ["expected_sha256"] } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "review_preview_request" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "action_id"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "action_id": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "review_preview_result" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request_id", "outcome"],
            "properties": {
              "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
              "outcome": { "enum": ["ok", "error"] },
              "detail": { "type": "string", "maxLength": 1000, "pattern": "^[^\\u0000]*$" },
              "url": { "type": "string", "maxLength": 4000, "pattern": "^http://127\\.0\\.0\\.1:[0-9]{1,5}/p/[A-Za-z0-9_-]+$" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "size_bytes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
              "expires_at": { "type": "string", "format": "date-time" }
            },
            "allOf": [
              {
                "if": { "properties": { "outcome": { "const": "ok" } }, "required": ["outcome"] },
                "then": {
                  "required": ["url", "sha256", "size_bytes", "expires_at"],
                  "not": { "required": ["detail"] }
                }
              },
              {
                "if": { "properties": { "outcome": { "const": "error" } }, "required": ["outcome"] },
                "then": {
                  "not": {
                    "anyOf": [
                      { "required": ["url"] },
                      { "required": ["sha256"] },
                      { "required": ["size_bytes"] },
                      { "required": ["expires_at"] }
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
