{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papio.dev/protocol/browser-v1.schema.json",
  "title": "papio browser bridge message v1",
  "description": "One framed native-messaging envelope between the MV3 extension and the papio native host. Locked protocol papio-browser/1. Metadata only — PDF bytes and secrets never cross this channel; encoded messages are capped at 262144 bytes; integers are capped at JavaScript's exact range; unknown types, fields, and null object members are rejected (fail closed). auth_pending/auth_returned deliberately have no URL/title fields: identity-provider addresses never leave the browser.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "type", "msg_id", "seq", "payload"],
  "properties": {
    "protocol": { "const": "papio-browser/1" },
    "type": {
      "enum": [
        "hello",
        "hello_ack",
        "job_offer",
        "job_accept",
        "job_reject",
        "auth_pending",
        "auth_returned",
        "download_started",
        "download_complete",
        "provider_outcome",
        "cancel",
        "ack",
        "error"
      ]
    },
    "msg_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
    "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,128}$" },
    "seq": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "enum": ["job_offer", "job_accept", "job_reject", "auth_pending", "auth_returned", "download_started", "download_complete", "provider_outcome", "cancel"] } } },
      "then": { "required": ["job_id"] }
    },
    {
      "if": { "properties": { "type": { "const": "hello" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["extension_version"],
            "properties": {
              "extension_version": { "type": "string", "maxLength": 50 },
              "adapter_versions": {
                "type": "object",
                "maxProperties": 50,
                "additionalProperties": { "type": "string", "maxLength": 50 }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "hello_ack" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "daemon_version": { "type": "string", "maxLength": 50 },
              "features": {
                "type": "array",
                "maxItems": 32,
                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
              },
              "resolver_origins": {
                "type": "array",
                "maxItems": 32,
                "items": { "type": "string", "maxLength": 300, "pattern": "^https://[a-z0-9.-]{3,253}(:[0-9]{1,5})?$" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "job_offer" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["openurl", "provider_hosts", "access_mode", "expires_at"],
            "properties": {
              "openurl": { "type": "string", "format": "uri", "maxLength": 4000 },
              "provider_hosts": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "items": { "type": "string", "pattern": "^[a-z0-9.-]{3,253}$" }
              },
              "expected": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "doi": { "type": "string", "maxLength": 300 },
                  "title": { "type": "string", "maxLength": 500 }
                }
              },
              "access_mode": { "enum": ["assisted", "maximal"] },
              "expires_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "enum": ["auth_pending", "auth_returned"] } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "elapsed_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "download_started" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["download_id", "filename"],
            "properties": {
              "download_id": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
              "filename": { "type": "string", "pattern": "^[^/\\\\]{1,255}$" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "download_complete" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["download_id", "filename", "size_bytes"],
            "properties": {
              "download_id": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
              "filename": { "type": "string", "pattern": "^[^/\\\\]{1,255}$" },
              "size_bytes": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "provider_outcome" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["outcome"],
            "properties": {
              "outcome": {
                "enum": [
                  "no_entitlement",
                  "document_delivery_available",
                  "wrong_work",
                  "ui_changed",
                  "rate_limited",
                  "terms_acceptance_required",
                  "human_auth_required",
                  "cancelled"
                ]
              },
              "adapter_version": { "type": "string", "maxLength": 50 },
              "detail": { "type": "string", "maxLength": 500 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "error" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string", "pattern": "^[a-z0-9_]{2,50}$" },
              "message": { "type": "string", "maxLength": 1000 }
            }
          }
        }
      }
    }
  ]
}
